# ====================
# OpenAI / LLM API (DashScope compatible)
# ====================
OPENAI_API_KEY=your_api_key_here
OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_DEFAULT_MODEL=qwen-flash
LLM_DEFAULT_TEMPERATURE=0.1
VL_MODEL=qwen3-vl-flash
ITEM_MODEL=qwen-flash
KG_MODEL=qwen-flash

# ====================
# BGE Embedding Models
# ====================
BGE_M3_PATH=/path/to/bge-m3
BGE_M3=BAAI/bge-m3
BGE_DEVICE=cuda:0
BGE_FP16=True
BGE_RERANKER_LARGE=/path/to/bge-reranker-large
BGE_RERANKER_DEVICE=cuda:0
BGE_RERANKER_FP16=1

# ====================
# Embedding General
# ====================
EMBEDDING_DIM=1536
EMBEDDING_MODEL=text-embedding-v4

# ====================
# Vector Database (Milvus)
# ====================
MILVUS_URL=http://localhost:19530
CHUNKS_COLLECTION=kb_chunks
ENTITY_NAME_COLLECTION=kb_graph_entity_names
ITEM_NAME_COLLECTION=kb_item_names
MILVUS_METRIC_TYPE=COSINE
MILVUS_MIN_COSINE_SCORE=0.75

# ====================
# Graph Database (Neo4j)
# ====================
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# ====================
# Document Database (MongoDB)
# ====================
MONGO_URL=mongodb://user:password@localhost:27017
MONGO_DB_NAME=kb001

# ====================
# Object Storage (MinIO)
# ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=your_access_key_here
MINIO_SECRET_KEY=your_secret_key_here
MINIO_BUCKET_NAME=knowledge-base

# ====================
# MCP / Web Search
# ====================
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/?tavilyApiKey=your_tavily_api_key_here
